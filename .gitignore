.Rproj.user
.Rhistory
.RData
.Ruserdata
.DS_Store
.Renviron
# Per-study agent prompts: working notes for the next session on that study,
# not part of the published repo.
studies/**/AGENT_PROMPT.md

# Diagnostic harness: a scratch file for dissecting one specification. Neither a
# numbered step nor a library, so it does not belong in scripts/ permanently.
studies/**/surgery.R
# Study outputs (large; download from GitHub release instead).
studies/**/*.dta
studies/**/*.rds
studies/**/*.zip
studies/**/*.csv
studies/**/*.xlsx
studies/**/*.png
# !studies/**/narrative/resource-extraction.html
# Package data slot kept lean.
data/*
# data-raw/ is private by default, but we track the documentation and
# scripts that live alongside the harmonized release.
data-raw/*
!data-raw/scripts/
!data-raw/releases/
data-raw/releases/*
!data-raw/releases/harmonized_data/
data-raw/releases/harmonized_data/*
!data-raw/releases/harmonized_data/README.md
!data-raw/releases/harmonized_data/README.Rmd
!data-raw/releases/harmonized_data/codebook.md
# Test fixtures (downloaded on demand).
tests/**/*.dta
tests/**/*.rds
tests/**/*.zip
tests/**/*.csv
tests/**/*.xlsx
tests/**/*.png
# Office lock files.
~$*
*.tmp
# pkgdown / R build artifacts.
docs/
inst/doc/
*.Rcheck/
*.tar.gz
replications
