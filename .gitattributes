# Normalise line endings across platforms.
* text=auto eol=lf

# Force LF for source code.
*.R         text eol=lf
*.Rmd       text eol=lf
*.Rd        text eol=lf
*.do        text eol=lf
*.py        text eol=lf
*.sh        text eol=lf
*.sbatch    text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.json      text eol=lf

# Treat binary research artifacts as binary (no diff, no merge).
*.dta       binary
*.rds       binary
*.RData     binary
*.xlsx      binary
*.xls       binary
*.docx      binary
*.doc       binary
*.pdf       binary
*.png       binary
*.jpg       binary
*.jpeg      binary
*.zip       binary
*.gz        binary
*.7z        binary

# GitHub Linguist hints: don't let manuscript text inflate the language stats.
manuscripts/**          linguist-documentation
data-raw/old_codes/**   linguist-vendored
studies/**/output/** linguist-generated
